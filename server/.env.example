# ───────────────────────────────────────────────────────────────
# Core (required)
# ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/rentalflow?retryWrites=true&w=majority

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Public URL of the frontend (used for CORS + agreement signing links)
CLIENT_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────────
# File storage — Cloudinary (optional; falls back to local disk)
# ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ───────────────────────────────────────────────────────────────
# Email (optional; logs to console if unset)
# Set EMAIL_PROVIDER to "sendgrid" or "smtp"
# ───────────────────────────────────────────────────────────────
EMAIL_PROVIDER=
EMAIL_FROM="RentalFlow <no-reply@rentalflow.app>"
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ───────────────────────────────────────────────────────────────
# SMS — Twilio (optional; logs to console if unset)
# ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Default country calling code used to normalise local numbers to E.164 (NZ = 64)
SMS_DEFAULT_COUNTRY=64

# ───────────────────────────────────────────────────────────────
# Reminders
# Days-before thresholds for expiry reminders (comma separated)
# ───────────────────────────────────────────────────────────────
REMINDER_DAYS=30,14,7,1
REMINDER_CRON=0 8 * * *
